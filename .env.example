# =============================================================================
# DEVELOPMENT SETTINGS
# Copy this section to your .env for local development
# =============================================================================
# DJANGO
SECRET_KEY=TU_SECRET_KEY_AQUI
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# DEVELOPMENT DATABASE (PostgreSQL local)
DB_NAME=arsforte_db
DB_USER=postgres
DB_PASS=tu_password_local
DB_HOST=localhost
DB_PORT=5432

# REDIS CACHE (optional in dev)
REDIS_URL=redis://localhost:6379/0
CACHE_KEY_PREFIX=arsforte

# RATE LIMITING
RATELIMIT_ENABLE=True
RATELIMIT_USE_CACHE=default
RATELIMIT_CACHE_PREFIX=rl:

# =============================================================================
# PRODUCTION SETTINGS
# Uncomment and fill for production deployment
# =============================================================================
# DJANGO
# DEBUG=False
# ALLOWED_HOSTS=tu-dominio.com,www.tu-dominio.com

# PRODUCTION DATABASE (Neon PostgreSQL)
# DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/arsforte_db?sslmode=require

# PRODUCTION SECURITY
# SECURE_SSL_REDIRECT=True
# SECURE_HSTS_SECONDS=31536000
# SECURE_HSTS_INCLUDE_SUBDOMAINS=True
# SECURE_HSTS_PRELOAD=True
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True

# REDIS CACHE (required in prod)
# REDIS_URL=redis://localhost:6379/0
# CACHE_KEY_PREFIX=arsforte
